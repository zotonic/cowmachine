// Cowmachine HTTP decision flow
// Based on the webmachine diagram by Maas-Maarten Zeeman, updated for cowmachine.
//
// Key differences from the webmachine / http-headers-status.dot diagram:
//
//  1. v3b6_upgrade added between forbidden? and valid_content_headers?
//     Cowmachine checks for a WebSocket / protocol upgrade before content checks.
//
//  2. v3h7 semantics differ: only If-Match: * causes 412 when the resource is
//     missing; a specific ETag still passes through to v3i7.
//
//  3. v3m20 calls process(DELETE) instead of delete_resource.
//
//  4. v3n11 POST path calls process(POST) instead of process_post.
//
//  5. v3m5 and v3n5 edge labels corrected (were reversed in the original diagram).
//
//  6. All controller callbacks are arity 1: Fun(Context) -> {Result, Context}.
//     Named content-type handler functions do not exist; process/4 handles all methods.

digraph CowmachineFSM {

    graph [center=start rankdir=TB]
    node [shape=box style=rounded];

    subgraph _cluster_500_responses {
        node [shape=rect style=solid color=red];
        500 501 503;
    };

    subgraph _cluster_400_responses {
        node [shape=rect style=solid color=orange];
        400 401 403 404 405 406 409 410 412 413 414 415;
    };

    subgraph _cluster_200_300_results {
        node [shape=rect style=solid color=green];
        200 201 202 204 300 301 303 304 307;
    };

    subgraph _cluster_answer {
        node [shape=rect style=solid color=green];
        upgrade
    };

    start [shape=Mdiamond];
    start -> "service_available?";

    "service_available?" -> "known_method?" [label="true" penwidth=3];
    "service_available?" -> 503 [label="false"];

    "known_method?" -> "uri_too_long?" [label="true" penwidth=3];
    "known_method?" -> 501 [label="false"];

    "uri_too_long?" -> "method_allowed?" [label="false" penwidth=3];
    "uri_too_long?" -> 414 [label="true"];

    "method_allowed?" -> "has_content_md5_header?" [label="true" penwidth=3];
    "method_allowed?" -> 405 [label="false"];

    "has_content_md5_header?" [label="Content-MD5 header exists?"];
    "has_content_md5_header?" -> "content_md5_valid?" [label=true];
    "has_content_md5_header?" -> "malformed_request?" [label=false];

    "content_md5_valid?" [label="Content-MD5 valid?"];
    "content_md5_valid?" -> "malformed_request?" [label="md5 ok"];
    "content_md5_valid?" -> 400 [label="md5 different"];

    "malformed_request?" -> 400 [label=true];
    "malformed_request?" -> "is_authorized?" [label=false penwidth=3];

    "is_authorized?" -> "forbidden?" [label="true" penwidth=3];
    "is_authorized?" -> 401 [label="false / binary challenge"];

    "forbidden?" -> 403 [label="true"];
    "forbidden?" -> "v3b6_upgrade" [label="false" penwidth=3];

    "v3b6_upgrade" [label="v3b6_upgrade\nUpgrade header + upgrades_provided?" shape=oval];
    "v3b6_upgrade" -> upgrade [label="chosen protocol"];
    "v3b6_upgrade" -> "valid_content_headers?" [label="none / no header" penwidth=3];

    "valid_content_headers?" -> "known_content_type?" [label="true" penwidth=3];
    "valid_content_headers?" -> 501 [label="false"];

    "known_content_type?" -> "valid_entity_length?" [label="true" penwidth=3];
    "known_content_type?" -> 415 [label="false"];

    "valid_entity_length?" -> "OPTIONS method?" [label="true" penwidth=3];
    "valid_entity_length?" -> 413 [label="false"];

    "OPTIONS method?" -> 200 [label="true, call options/1"];
    "OPTIONS method?" -> "has_accept_header?" [label="false"];

    "has_accept_header?" [shape=oval,label="Accept header exists?"];
    "has_accept_header?" -> "do_select_content_type" [label=false];
    "has_accept_header?" -> "do_choose_content_type" [label=true];

    "do_select_content_type" [label="select first from\ncontent_types_provided/1"];
    "do_select_content_type" -> "has_accept_language_header?";

    "do_choose_content_type" [label="choose from\ncontent_types_provided/1"];
    "do_choose_content_type" -> "has_accept_language_header?";
    "do_choose_content_type" -> 406 [label="no media type chosen"];

    "has_accept_language_header?" [label="Accept-Language header exists?" shape=oval];
    "has_accept_language_header?" -> "do_choose_charset" [label="false"];
    "has_accept_language_header?" -> "language_available?" [label="true"];

    "language_available?" -> "do_choose_charset" [label="true"];
    "language_available?" -> 406 [label="false"];

    "do_choose_charset" [label="charsets_provided/1"];
    "do_choose_charset" -> v3f6;
    "do_choose_charset" -> 406 [label="no acceptable charset"];

    v3f6 [label="v3f6\ncontent_encodings_provided/1\n(set Content-Type header)"];
    v3f6 -> v3g7;
    v3f6 -> v3f7;
    v3f6 -> 406;

    v3f7 [label="v3f7\nchoose encoding" shape=oval];
    v3f7 -> v3g7 [label="got an encoding"];
    v3f7 -> 406 [label="no acceptable encoding"];

    v3g7 [label="v3g7\nresource_exists/1\n(variances set here)"]
    v3g7 -> v3g8 [label="true" penwidth=3];
    v3g7 -> v3h7 [label="false"];

    v3g8 [label="v3g8\nIf-Match exists?" shape=oval];
    v3g8 -> v3g9 [label=exists];
    v3g8 -> v3h10 [label=undefined];

    v3g9 [label="v3g9\nIf-Match: * exists" shape=oval];
    v3g9 -> v3h10 [label=true];
    v3g9 -> v3g11 [label=false];

    v3g11 [label="v3g11\ngenerate_etag/1\nETag in If-Match?"]
    v3g11 -> v3h10 [label="ETag matches"];
    v3g11 -> 412 [label="ETag missing"];

    // Cowmachine: only If-Match: * causes 412 when resource is missing.
    // A specific ETag on a missing resource falls through to v3i7.
    v3h7 [label="v3h7\nIf-Match: * present\non missing resource?" shape=oval];
    v3h7 -> 412 [label="If-Match: *"];
    v3h7 -> v3i7 [label="other / none" penwidth=3];

    v3h10 [label="v3h10\nIf-Unmodified-Since exists?" shape=oval];
    v3h10 -> v3i12 [label=undefined];
    v3h10 -> v3h11 [label=exists];

    v3h11 [label="v3h11\nIf-Unmodified-Since is valid date?" shape=oval];
    v3h11 -> v3i12 [label="bad date"];
    v3h11 -> v3h12 [label="valid"];

    v3h12 [label="v3h12\nlast_modified/1"];
    v3h12 -> v3i12 [label="not modified"];
    v3h12 -> 412 [label="modified after I-UM-S"];

    v3i4 [label="v3i4\nmoved_permanently/1\n(PUT to different URI)"];
    v3i4 -> v3p3 [label="false" penwidth=3];
    v3i4 -> 301 [label="{true, URL}"];

    v3i7 [label="v3i7\nPUT?" shape=oval]
    v3i7 -> v3i4 [label="true"];
    v3i7 -> v3k7 [label="false" penwidth=3];

    v3i12 [label="v3i12\nIf-None-Match exists?" shape=oval];
    v3i12 -> v3l13 [label="false"];
    v3i12 -> v3i13 [label="true"];

    v3i13 [label="v3i13\nIf-None-Match: * exists?" shape=oval];
    v3i13 -> v3j18 [label="*"];
    v3i13 -> v3k13 [label="other"];

    v3j18 [label="v3j18\nGET or HEAD?" shape=oval];
    v3j18 -> 304 [label=true];
    v3j18 -> 412 [label=false];

    v3k5 [label="v3k5\nmoved_permanently/1"];
    v3k5 -> v3l5 [label="false" penwidth=3];
    v3k5 -> 301 [label="{true, URL}"];

    v3k7 [label="v3k7\npreviously_existed/1"];
    v3k7 -> v3k5 [label="true"];
    v3k7 -> v3l7 [label="false" penwidth=3];

    v3k13 [label="v3k13\ngenerate_etag/1\nETag in If-None-Match?"];
    v3k13 -> v3l13 [label="ETag missing"];
    v3k13 -> v3j18 [label="ETag matches"];

    v3l5 [label="v3l5\nmoved_temporarily/1"]
    v3l5 -> v3m5 [label="false" penwidth=3];
    v3l5 -> 307 [label="{true, URL}"];

    v3l7 [label="v3l7\nPOST?" shape=oval];
    v3l7 -> v3m7 [label=true];
    v3l7 -> 404 [label=false penwidth=3];

    v3l13 [label="v3l13\nIf-Modified-Since exists?" shape=oval];
    v3l13 -> v3m16 [label=undefined];
    v3l13 -> v3l14 [label=exists];

    v3l14 [label="v3l14\nIf-Modified-Since is valid date?" shape=oval];
    v3l14 -> v3m16 [label="bad date"];
    v3l14 -> v3l15 [label="valid"];

    v3l15 [label="v3l15\nIf-Modified-Since > Now?" shape=oval];
    v3l15 -> v3m16 [label=true];
    v3l15 -> v3l17 [label=false];

    v3l17 [label="v3l17\nlast_modified/1\nLast-Modified > IMS?" shape=oval];
    v3l17 -> v3m16 [label="yes (modified)"];
    v3l17 -> 304 [label="no (not modified)"];

    // Corrected: POST method continues to v3n5; non-POST is 410 (gone).
    v3m5 [label="v3m5\nPOST?" shape=oval];
    v3m5 -> v3n5 [label=true];
    v3m5 -> 410 [label=false penwidth=3];

    v3m7 [label="v3m7\nallow_missing_post/1"];
    v3m7 -> v3n11 [label="true"];
    v3m7 -> 404 [label="false" penwidth=3];

    v3m16 [label="v3m16\nDELETE?" shape=oval];
    v3m16 -> v3m20 [label=true];
    v3m16 -> v3n16 [label=false penwidth=3];

    // Cowmachine calls process(<<"DELETE">>, ...) — not delete_resource/1.
    v3m20 [label="v3m20\nprocess(DELETE)"]
    v3m20 -> v3m20b [label=true];
    v3m20 -> 500 [label=false];

    v3m20b [label="v3m20b\ndelete_completed/1"];
    v3m20b -> 202 [label=false];
    v3m20b -> v3o20 [label=true penwidth=3];

    // Corrected: allow_missing_post=true continues to v3n11; false is 410 (gone).
    v3n5 [label="v3n5\nallow_missing_post/1"]
    v3n5 -> v3n11 [label="true" penwidth=3];
    v3n5 -> 410 [label=false];

    v3n11 [label="v3n11\npost_is_create/1"];
    v3n11 -> "create_path?" [label=true];
    // Cowmachine calls process(<<"POST">>, ...) — not process_post/1.
    v3n11 -> "process(POST)" [label=false];

    "create_path?" [label="create_path/1\nbase_uri/1"];
    "create_path?" -> v3p11 [label="path set"];
    "create_path?" -> 500 [label="undefined"];

    "process(POST)" [label="process(POST)\nvia accept_process_helper"]
    "process(POST)" -> v3p11;
    "process(POST)" -> 303 [label="set_resp_redirect=true"];

    v3n16 [label="v3n16\nPOST?"];
    v3n16 -> v3n11 [label=true];
    v3n16 -> v3o16 [label=false penwidth=3];

    v3o14 [label="v3o14\nis_conflict/1\n(PUT)"];
    v3o14 -> 409 [label="true"];
    v3o14 -> v3p11 [label="false" penwidth=3];

    v3o16 [label="v3o16\nPUT?" shape=oval];
    v3o16 -> v3o14 [label=true];
    v3o16 -> v3o18 [label=false penwidth=3];

    // Cowmachine calls process/4 for GET/HEAD body generation.
    v3o18 [label="v3o18\nprocess(GET|HEAD)\nvia process_helper" shape=oval];
    v3o18 -> v3o18b;

    v3o18b [label="v3o18b\nmultiple_choices/1"];
    v3o18b -> 200 [label="false" penwidth=3];
    v3o18b -> 300 [label="true"];

    v3o20 [label="v3o20\nResponse body set?" shape=oval];
    v3o20 -> v3o18 [label="true"];
    v3o20 -> 204 [label="false"];

    v3p3 [label="v3p3\nis_conflict/1\n(PUT to existing)"];
    v3p3 -> v3p11 [label="false" penwidth=3];
    v3p3 -> 409 [label="true"];

    v3p11 [label="v3p11\nLocation header set?" shape=oval];
    v3p11 -> 201 [label=true];
    v3p11 -> v3o20 [label=false];

    200 [label="200\nOK"];
    201 [label="201\nCreated"];
    202 [label="202\nAccepted"];
    204 [label="204\nNo Content"];

    300 [label="300\nMultiple Choices"];
    301 [label="301\nMoved Permanently"];
    303 [label="303\nSee Other"];
    304 [label="304\nNot Modified"];
    307 [label="307\nTemporary Redirect"];

    400 [label="400\nBad Request"];
    401 [label="401\nUnauthorized"];
    403 [label="403\nForbidden"];
    404 [label="404\nNot Found"];
    405 [label="405\nMethod Not Allowed"];
    406 [label="406\nNot Acceptable"];
    409 [label="409\nConflict"];
    410 [label="410\nGone"];
    412 [label="412\nPrecondition Failed"];
    413 [label="413\nRequest Entity Too Large"];
    414 [label="414\nRequest-URI Too Long"];
    415 [label="415\nUnsupported Media Type"];

    500 [label="500\nInternal Server Error"];
    501 [label="501\nNot Implemented"];
    503 [label="503\nService Unavailable"];
}
